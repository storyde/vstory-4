[? if qol-purpose != 0 and part-of != "individual" : We are about: [+ qol-purpose +] ?]
[? if qol-aspiration != 0 and part-of = "individual" : I want to be: [+ qol-aspiration +] ?]
[? if qol-aspiration != 0 and part-of != "individual" : We want to be: [+ qol-aspiration +] ?]
[? if qol-accomplish != 0 and part-of = "individual" : I ultimately want to accomplish: [+ qol-accomplish +] ?]
[? if qol-accomplish != 0 and part-of != "individual" : We ultimately want to accomplish: [+ qol-accomplish +] ?]
[? if textarea != 0 : [+ textarea +] ?]

[? if frb-people != 0 or frb-environment != 0 : **Future Resource Base** ?]
[? if frb-people != 0 : Our behaviour: [+ frb-people +] ?]
[? if frb-environment != 0 : Environment: [+ frb-environment +] ?]

