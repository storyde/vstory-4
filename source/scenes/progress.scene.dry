[? if decision-makers != 0 : Decision makers: [+ decision-makers +] ?]
[? if rb-physical != 0 : Physical resources: [+ rb-physical +] ?]
[? if rb-human != 0 : Social resources: [+ rb-human +] ?]
[? if wum-money != 0 : Moneytary resources: [+ wum-money +] ?]

[? if part-of = "org" and st-purpose != 0 : **Statement of Purpose** ?]
[? if part-of = "org" and st-purpose != 0 : [+ st-purpose +] ?]

